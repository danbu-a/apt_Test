# 공공데이터포털(data.go.kr)에서 발급받은 서비스키를 넣으세요.
# 국토교통부 실거래가/한국부동산원 단지식별정보/법정동코드/건축HUB 4개 API가 모두 이 키를 씁니다.
# 이 파일을 복사해 .env로 저장한 뒤 실제 값을 채우면 됩니다(.env는 git에 올라가지 않습니다).
DATA_GO_KR_SERVICE_KEY=

# 한국부동산원(R-ONE) 부동산 통계 정보 오픈 API 인증키 - 위 DATA_GO_KR_SERVICE_KEY와는
# 별도 발급 키입니다. https://www.reb.or.kr/r-one/ 에서 발급받아 채우세요.
REB_STATS_API_KEY=

# (선택) 등기(건축물대장) 온디맨드 조회 캐시를 재배포/재기동에도 살아남게 하려면
# S3 호환 오브젝트 스토리지(Backblaze B2, Cloudflare R2, AWS S3, MinIO 등) 정보를
# 채우세요. 비워두면 기존처럼 로컬 파일에만 저장합니다(Render 등에서는 재기동마다
# 초기화됨). remoteStorage.js 참고.
REMOTE_STORAGE_ENDPOINT=<YOUR_S3_COMPATIBLE_ENDPOINT>
REMOTE_STORAGE_BUCKET=<YOUR_BUCKET_NAME>
REMOTE_STORAGE_REGION=<YOUR_REGION>
REMOTE_STORAGE_ACCESS_KEY_ID=<YOUR_ACCESS_KEY_ID>
REMOTE_STORAGE_SECRET_ACCESS_KEY=<YOUR_SECRET_ACCESS_KEY>
